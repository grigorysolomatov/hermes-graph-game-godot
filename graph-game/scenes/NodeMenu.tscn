[gd_scene format=3 uid="uid://node_menu_scene"]

[ext_resource type="Script" path="res://scripts/node_menu.gd" id="1_nodemenu"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.12, 0.12, 0.15, 0.95)
corner_radius_top_left = 10
corner_radius_top_right = 10

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn"]
bg_color = Color(0.2, 0.2, 0.25, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btnhov"]
bg_color = Color(0.3, 0.3, 0.38, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_toggle"]
bg_color = Color(0.18, 0.18, 0.22, 0.9)
corner_radius_top_left = 6
corner_radius_top_right = 6

[node name="NodeMenu" type="Control"]
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -120.0
offset_bottom = 0.0
script = ExtResource("1_nodemenu")

[node name="ToggleBtn" type="Button" parent="."]
layout_mode = 0
position = Vector2(8, -36)
size = Vector2(60, 36)
theme_override_styles/normal = SubResource("StyleBoxFlat_toggle")
theme_override_styles/hover = SubResource("StyleBoxFlat_toggle")
theme_override_styles/pressed = SubResource("StyleBoxFlat_toggle")
theme_override_colors/font_color = Color(0.85, 0.85, 0.85, 1)
text = "-"

[node name="Panel" type="Panel" parent="."]
layout_mode = 1
anchor_left = 0.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = 0.0
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="HBox" type="HBoxContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 12.0
offset_right = -16.0
offset_bottom = -12.0
theme_override_constants/separation = 16

[node name="WorkerBtn" type="Button" parent="Panel/HBox"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(80, 88)
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btnhov")
theme_override_styles/pressed = SubResource("StyleBoxFlat_btn")
theme_override_colors/font_color = Color(0.961, 0.620, 0.043, 1)
text = "Worker"

[node name="SeaBtn" type="Button" parent="Panel/HBox"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(80, 88)
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover = SubResource("StyleBoxFlat_btnhov")
theme_override_styles/pressed = SubResource("StyleBoxFlat_btn")
theme_override_colors/font_color = Color(0.078, 0.722, 0.651, 1)
text = "Sea"

[connection signal="pressed" from="ToggleBtn" to="." method="_on_toggle_pressed"]
[connection signal="button_down" from="Panel/HBox/WorkerBtn" to="." method="_on_worker_drag_started"]
[connection signal="button_down" from="Panel/HBox/SeaBtn" to="." method="_on_sea_drag_started"]
